--Estadisticas y Gatillo de Victoria
local function formatNumber(v)
    return tostring(v):reverse():gsub("%d%d%d", "%1,"):reverse():gsub("^,", "")
end

local isHopping = false
local function HopBugeado()
    if isHopping then return end
    isHopping = true
    local nextCursor = ""
    local serverFound = false
    while not serverFound do
        local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"
        if nextCursor ~= "" then url = url .. "&cursor=" .. nextCursor end
        local success, result = pcall(function() return game:HttpGet(url) end)
        if success and result then
            local decoded = HttpService:JSONDecode(result)
            if decoded and decoded.data then
                local list = decoded.data
                for i = #list, 2, -1 do
                    local j = math.random(i)
                    list[i], list[j] = list[j], list[i]
                end
                for _, server in ipairs(list) do
                    if server.id ~= game.JobId and server.playing and server.maxPlayers then
                        if server.playing < server.maxPlayers and server.playing >= 5 then
                            serverFound = true
                            pcall(function() TS:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer) end)
                            task.wait(2)
                            if not serverFound then break end
                        end
                    end
                end
                if decoded.nextPageCursor then nextCursor = decoded.nextPageCursor else break end
            else break end
        else break end
        task.wait(1)
    end
    if not serverFound then pcall(function() TS:Teleport(game.PlaceId, LocalPlayer) end) end
end

local currentBrawls = 0
local function updateBrawls()
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if leaderstats and leaderstats:FindFirstChild("Brawls") then
        local b = leaderstats.Brawls.Value
        local text = ""
        if b >= 1000000 then
            text = formatNumber(math.floor(b / 1000)) .. "K (" .. string.format("%.2f", b / 1000000) .. "M)"
        elseif b >= 1000 then
            text = formatNumber(b) .. " (" .. string.format("%.1f", b / 1000) .. "K)"
        else
            text = tostring(b) .. " (0K)"
        end
        brawlsLabel.Text = text
    end
end

task.spawn(function()
    local leaderstats = LocalPlayer:WaitForChild("leaderstats", 10)
    if leaderstats and leaderstats:FindFirstChild("Brawls") then
        currentBrawls = leaderstats.Brawls.Value
        updateBrawls()
        
        --Si ganas un Brawl, salta de servidor enseguida
        leaderstats.Brawls.Changed:Connect(function(newVal)
            updateBrawls()
            if newVal > currentBrawls then
                currentBrawls = newVal
                task.wait(1)
                HopBugeado()
            end
        end)
    end
end)

--Reloj y FPS
local cStart = os.clock()
local lastUpdate = 0
local frameCount = 0

RunService.RenderStepped:Connect(function() frameCount = frameCount + 1 end)

RunService.Heartbeat:Connect(function()
    local currentTime = os.clock()
    local cElapsed = currentTime - cStart
    ChronoLabel.Text = string.format("%02d:%02d.%02d", math.floor(cElapsed / 60), math.floor(cElapsed % 60), math.floor((cElapsed * 100) % 100))
    if currentTime - lastUpdate >= 1 then
        local pingVal = math.round(LocalPlayer:GetNetworkPing() * 1000)
        if pingVal <= 0 then pingVal = math.random(15, 45) end
        statsLabel.Text = string.format("PING: %d ms\nFPS: %d FPS", pingVal, frameCount)
        frameCount = 0
        lastUpdate = currentTime
    end
end)

--Entrada Automatica al Brawl
local initialPosition = nil
local isInBrawlArena = false
local arenaTime = 0
local hadEnemies = false
local secretPosition = CFrame.new(1949, 2, 6193)

task.spawn(function()
    while task.wait(1) do
        --Solo manda el evento si NO estamos dentro de la arena peleando
        if not isInBrawlArena then
            pcall(function()
                local rEvents = ReplicatedStorage:FindFirstChild("rEvents")
                if rEvents and rEvents:FindFirstChild("brawlEvent") then
                    rEvents.brawlEvent:FireServer("joinBrawl")
                end
            end)
        end
    end
end)

--Funciones del Personaje
local function applySize2()
    local character = LocalPlayer.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        for _, value in ipairs(humanoid:GetChildren()) do
            if value:IsA("NumberValue") and value.Name:find("Scale") then
                if value.Value ~= 2 then value.Value = 2 end
            end
        end
    end
end

--Teleport Perfecto, Auto Kill y Detector de Enemigos en la Arena
RunService.Heartbeat:Connect(function(deltaTime)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    
    if not root then return end

    if not initialPosition and root.Position.Magnitude < 2000 then
        initialPosition = root.Position
    end

    if initialPosition then
        local dist = (root.Position - initialPosition).Magnitude
        
        --Si la distancia es mayor a 800, el servidor nos metio a la arena
        if dist > 800 or isInBrawlArena then
            if not isInBrawlArena then
                isInBrawlArena = true
                arenaTime = 0
                hadEnemies = false
            end
            
            arenaTime = arenaTime + deltaTime

            --Detector: Revisa si alguien mas entro a la arena contigo
            if not hadEnemies then
                for _, target in ipairs(Players:GetPlayers()) do
                    if target ~= LocalPlayer and target.Character then
                        local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
                        if targetRoot then
                            --Si un enemigo esta a menos de 500 studs del centro de la arena
                            if (targetRoot.Position - secretPosition.Position).Magnitude < 500 then
                                hadEnemies = true
                            end
                        end
                    end
                end
            end
            
            --Anti-Stuck de 90 segundos por si se bugea
            if arenaTime > 90 then
                HopBugeado()
            end

            --Traba la posicion EXACTA que pediste y cancela el movimiento
            root.Velocity = Vector3.zero
            root.AssemblyLinearVelocity = Vector3.zero
            root.CFrame = secretPosition

            --Activacion del Auto Kill
            if char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
                applySize2()
                
                local rightHand = char:FindFirstChild("RightHand")
                local leftHand = char:FindFirstChild("LeftHand")
                local tool = LocalPlayer.Backpack:FindFirstChild("Punch") or char:FindFirstChild("Punch")
                
                if tool then
                    tool.Parent = char
                    if tool:FindFirstChild("attackTime") then tool.attackTime.Value = 0 end
                    pcall(function() tool:Activate() end)
                end
                
                if rightHand and leftHand then
                    for _, target in ipairs(Players:GetPlayers()) do
                        if target ~= LocalPlayer and target.Character then
                            local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
                            local targetHumanoid = target.Character:FindFirstChild("Humanoid")
                            
                            if targetRoot and targetHumanoid and targetHumanoid.Health > 0 then
                                pcall(function()
                                    firetouchinterest(rightHand, targetRoot, 1)
                                    firetouchinterest(leftHand, targetRoot, 1)
                                    firetouchinterest(rightHand, targetRoot, 0)
                                    firetouchinterest(leftHand, targetRoot, 0)
                                end)
                            end
                        end
                    end
                end
            end
        else
            --Regresaste al lobby
            if isInBrawlArena then
                isInBrawlArena = false
                arenaTime = 0
                
                --Si estuviste en la arena sin nadie mas, salta de servidor inmediatamente
                if not hadEnemies then
                    HopBugeado()
                end
                
                hadEnemies = false
            end
        end
    end
end)

