local function checkAndHideGui(gui)
    if gui:IsA("TextLabel") or gui:IsA("ImageLabel") or gui:IsA("Frame") then
        if gui.Name == "ApexBrawlGUI" or gui:IsDescendantOf(playerGui:FindFirstChild("ApexBrawlGUI")) then return end
        local nameLower = gui.Name:lower()
        local textLower = gui:IsA("TextLabel") and gui.Text:lower() or ""
        
        if nameLower:match("frame$") or nameLower:find("push") or nameLower:find("gain") or nameLower:find("popup") or nameLower:find("clone") or 
           nameLower:find("notification") or textLower:find("durabilidade") or textLower:find("durability") or 
           textLower:find("+") or textLower:find("kill") or textLower:find("ganhou") then
            
            gui.Visible = false
            if gui:IsA("TextLabel") then gui.TextTransparency = 1 end
            if gui:IsA("ImageLabel") then gui.ImageTransparency = 1 end
        end
    end
end
