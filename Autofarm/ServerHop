--Sistema Auto Kill Exclusivo para Brawl
local tickCounter = 0
RunService.Heartbeat:Connect(function()
    tickCounter = tickCounter + 1
    if tickCounter % 2 ~= 0 then return end 
    applySize2()
    
    if not isInBrawlArena then return end

    local char = LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
        stopAnimations(char.Humanoid)
        
        local tool = LocalPlayer.Backpack:FindFirstChild("Punch") or char:FindFirstChild("Punch")
        if tool then
            char.Humanoid:EquipTool(tool)
            if tool:FindFirstChild("attackTime") then tool.attackTime.Value = 0 end
            pcall(function() tool:Activate() end)
        end
        
        local rightHand = char:FindFirstChild("RightHand")
        if rightHand and initialPosition then
            for _, target in ipairs(Players:GetPlayers()) do
                if target ~= LocalPlayer and target.Character then
                    local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
                    local targetHead = target.Character:FindFirstChild("Head")
                    local targetHumanoid = target.Character:FindFirstChild("Humanoid")
                    
                    if targetRoot and targetHead and targetHumanoid and targetHumanoid.Health > 0 then
                        --Verifica si el enemigo esta en la arena del Brawl
                        local targetDist = (targetRoot.Position - initialPosition).Magnitude
                        if targetDist > 800 then
                            pcall(function()
                                firetouchinterest(rightHand, targetRoot, 1)
                                firetouchinterest(rightHand, targetRoot, 0)
                                firetouchinterest(rightHand, targetHead, 1)
                                firetouchinterest(rightHand, targetHead, 0)
                            end)
                        end
                    end
                end
            end
        end
    end
end)

--Detector de Brawl y Entrada Segura (1 Segundo Despues)
local joinedBrawl = false
task.spawn(function()
    while task.wait(0.5) do
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        
        if root then
            if not initialPosition and root.Position.Magnitude < 1000 then
                initialPosition = root.Position
            end

            if initialPosition then
                local dist = (root.Position - initialPosition).Magnitude
                if dist > 800 then
                    isInBrawlArena = true
                end
            end
        end

        --Detecta la interfaz del juego para confirmar inicio de Brawl
        if not joinedBrawl and not isInBrawlArena then
            local ui = playerGui:FindFirstChild("gameGui")
            if ui and ui:FindFirstChild("brawlFrame") and ui.brawlFrame.Visible then
                joinedBrawl = true -- Bloquea para entrar solo 1 vez
                task.wait(1) -- Espera exactamente 1 segundo despues de iniciado
                pcall(function()
                    local r = ReplicatedStorage:FindFirstChild("rEvents")
                    if r and r:FindFirstChild("brawlEvent") then
                        r.brawlEvent:FireServer("joinBrawl")
                    end
                end)
            end
        end
    end
end)

