-- Loop de Entrada com Trava Absoluta (One-Brawl-Per-Server)
local lastJoinAttempt = 0

task.spawn(function()
    while task.wait(1) do
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        
        if root then
            -- Captura a posição inicial (Lobby) apenas se estiver perto do centro
            if not initialPosition and root.Position.Magnitude < 2000 then
                initialPosition = root.Position
            end

            if initialPosition then
                local distanceFromStart = (root.Position - initialPosition).Magnitude

                if distanceFromStart > 800 then
                    -- Estamos na arena
                    if not isInBrawlArena then
                        isInBrawlArena = true
                        jaParticipou = true -- TRAVA ABSOLUTA: Bloqueia reentrada neste server pra sempre
                    end
                else
                    -- Estamos no Lobby
                    if isInBrawlArena then
                        isInBrawlArena = false
                        -- Gatilho de Segurança: Se fomos devolvidos pro Lobby após um Brawl e não ganhamos, pula de servidor na hora!
                        task.spawn(function()
                            task.wait(3)
                            ExecuteRealServerHop()
                        end)
                    end

                    -- Entra no Brawl SOMENTE se nunca tiver participado neste servidor
                    if not jaParticipou and (os.clock() - lastJoinAttempt > 10) then
                        lastJoinAttempt = os.clock()
                        pcall(function()
                            local rEvents = ReplicatedStorage:FindFirstChild("rEvents")
                            if rEvents and rEvents:FindFirstChild("brawlEvent") then
                                rEvents.brawlEvent:FireServer("joinBrawl")
                            end
                        end)
                    end
                end
            end
        end
    end
end)

